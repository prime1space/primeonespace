# Backend API .htaccess
RewriteEngine On

# Handle CORS preflight requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route API requests to router.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api/router.php [QSA,L]

# Security
<Files "*.php">
    Order allow,deny
    Allow from all
</Files>

<Files "db.php">
    Order deny,allow
    Deny from all
</Files>

<Files "schema.sql">
    Order deny,allow
    Deny from all
</Files>