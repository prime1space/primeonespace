# Backend Environment Variables
# IMPORTANT: Never commit this file to Git! Add to .gitignore

# Email Service (Brevo/Sendinblue - FREE: 300 emails/day, 9,000/month)
# Sign up at: https://www.brevo.com
BREVO_API_KEY=your_brevo_api_key_here

# Stripe Payment Gateway
# Sign up at: https://stripe.com
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Database Configuration (Production)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=primeonelk_user_coworking
# DB_USER=primeonelk_user_coworking
# DB_PASS=your_production_password_here

# Security
# SESSION_LIFETIME=604800  # 7 days in seconds
# CSRF_TOKEN_LIFETIME=3600  # 1 hour in seconds

# Rate Limiting
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=60
# LOGIN_LOCKOUT_SECONDS=900  # 15 minutes

# REGISTER_MAX_ATTEMPTS=3
# REGISTER_WINDOW_SECONDS=3600  # 1 hour
# REGISTER_LOCKOUT_SECONDS=3600  # 1 hour

# Application
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://primeone.space
